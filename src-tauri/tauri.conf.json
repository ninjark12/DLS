{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "dynamic-layer-switcher",
  "version": "0.1.0",
  "identifier": "com.kapoo.dynamic-layer-switcher",
  "build": {
    "beforeDevCommand": "bun run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist/dynamic-layer-switcher/browser"
  },
  "app": {
    "windows": [
      {
        "title": "dynamic-layer-switcher",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/dfu-util.exe",
      "resources/iris_lm_dls.bin"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
